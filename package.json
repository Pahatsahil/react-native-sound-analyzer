{
  "name": "react-native-sound-analyzer",
  "version": "1.0.0",
  "description": "Real-time audio recording and sound type detection for React Native (Android)",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native.config.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "audio",
    "sound",
    "recorder",
    "analyzer",
    "scream-detection",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Pahatsahil/react-native-sound-analyzer"
  },
  "author": "sahilpahat051",
  "bugs": {
    "url": "https://github.com/Pahatsahil/react-native-sound-analyzer/issues"
  },
  "homepage": "https://github.com/Pahatsahil/react-native-sound-analyzer#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.74.0",
    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
